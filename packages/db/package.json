{
  "name": "@playground/db",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": {
      "require": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./client": {
      "require": "./src/client.ts",
      "import": "./src/client.ts",
      "types": "./src/client.ts"
    },
    "./schema": {
      "require": "./src/schema/index.ts",
      "import": "./src/schema/index.ts",
      "types": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@playground/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
